<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <DropShadowEffect
        x:Key="WorkspaceCardShadow"
        BlurRadius="16"
        Color="#162A38"
        Opacity="0.06"
        ShadowDepth="2" />

    <DropShadowEffect
        x:Key="ButtonShadow"
        x:Shared="False"
        BlurRadius="10"
        Color="#16323C"
        Opacity="0.14"
        ShadowDepth="2" />

    <DropShadowEffect
        x:Key="ToolbarButtonShadow"
        x:Shared="False"
        BlurRadius="7"
        Color="#16323C"
        Opacity="0.09"
        ShadowDepth="1" />

    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
    </Style>

    <Style x:Key="SectionTitleText" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
    </Style>

    <Style x:Key="SupportingText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>

    <Style x:Key="WorkspaceCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Effect" Value="{StaticResource WorkspaceCardShadow}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="PanelCardStyle" TargetType="materialDesign:Card">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UniformCornerRadius" Value="12" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0" />
    </Style>

    <ControlTemplate x:Key="AppButtonTemplate" TargetType="Button">
        <Border
            x:Name="ButtonSurface"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="8"
            SnapsToDevicePixels="True">
            <ContentPresenter
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                Content="{TemplateBinding Content}"
                ContentStringFormat="{TemplateBinding ContentStringFormat}"
                ContentTemplate="{TemplateBinding ContentTemplate}"
                RecognizesAccessKey="True"
                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
        </Border>
    </ControlTemplate>

    <Style x:Key="AppButtonBase" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Height" Value="44" />
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{DynamicResource SoftAccentBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Effect" Value="{StaticResource ButtonShadow}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}" />
        <Setter Property="Template" Value="{StaticResource AppButtonTemplate}" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonPressedBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource SoftAccentBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                <Setter Property="Opacity" Value="0.62" />
                <Setter Property="Effect" Value="{x:Null}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource AppButtonBase}">
        <Setter Property="MinWidth" Value="144" />
        <Setter Property="Background" Value="{DynamicResource PrimaryActionBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource PrimaryActionHoverBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PrimaryActionPressedBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource DisabledBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource AppButtonBase}">
        <Setter Property="Background" Value="{DynamicResource PrimaryActionBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
        <Setter Property="Effect" Value="{StaticResource ButtonShadow}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource PrimaryActionHoverBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PrimaryActionPressedBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource DisabledBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Any regular button without a specialized style uses the same filled action treatment.  -->
    <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButton}" />

    <Style x:Key="BrowseActionButton" TargetType="Button" BasedOn="{StaticResource SecondaryActionButton}">
        <Setter Property="Width" Value="104" />
        <Setter Property="MinWidth" Value="104" />
    </Style>

    <Style x:Key="CompactActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="76" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="ToolbarActionButton" TargetType="Button" BasedOn="{StaticResource SecondaryActionButton}">
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="116" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="DialogActionButton" TargetType="Button" BasedOn="{StaticResource SecondaryActionButton}">
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="DialogPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="AppSliderThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Background" Value="{DynamicResource PrimaryActionBrush}" />
        <Setter Property="Effect" Value="{StaticResource ButtonShadow}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border
                        x:Name="ThumbSurface"
                        Background="{TemplateBinding Background}"
                        CornerRadius="9" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter
                                TargetName="ThumbSurface"
                                Property="Background"
                                Value="{DynamicResource PrimaryActionHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter
                                TargetName="ThumbSurface"
                                Property="Background"
                                Value="{DynamicResource PrimaryActionPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter
                                TargetName="ThumbSurface"
                                Property="Background"
                                Value="{DynamicResource DisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Slider">
        <Setter Property="Height" Value="30" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid
                        Margin="4,0"
                        Background="Transparent"
                        SnapsToDevicePixels="True">
                        <Track
                            x:Name="PART_Track"
                            Height="18"
                            VerticalAlignment="Center"
                            IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                            Orientation="Horizontal">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton
                                    Height="18"
                                    VerticalAlignment="Center"
                                    Command="{x:Static Slider.DecreaseLarge}"
                                    CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                    Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border
                                                Height="4"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource PrimaryActionBrush}"
                                                CornerRadius="2" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource AppSliderThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton
                                    Height="18"
                                    VerticalAlignment="Center"
                                    Command="{x:Static Slider.IncreaseLarge}"
                                    CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                    Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border
                                                Height="4"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource GridLineBrush}"
                                                CornerRadius="2" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_Track" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarLineButtonStyle" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border
                        x:Name="LineButtonSurface"
                        Background="{TemplateBinding Background}"
                        CornerRadius="5">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter
                                TargetName="LineButtonSurface"
                                Property="Background"
                                Value="{DynamicResource HoverBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarPageButtonStyle" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="Background" Value="{DynamicResource SubtleTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border
                        x:Name="ScrollThumbSurface"
                        Background="{TemplateBinding Background}"
                        CornerRadius="4" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter
                                TargetName="ScrollThumbSurface"
                                Property="Background"
                                Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter
                                TargetName="ScrollThumbSurface"
                                Property="Background"
                                Value="{DynamicResource PrimaryActionPressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="VerticalAppScrollBarTemplate" TargetType="ScrollBar">
        <Grid Width="14" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="14" />
            </Grid.RowDefinitions>
            <RepeatButton
                Grid.Row="0"
                Command="{x:Static ScrollBar.LineUpCommand}"
                CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                Style="{StaticResource ScrollBarLineButtonStyle}">
                <Path
                    Width="7"
                    Height="4"
                    Data="M 0 4 L 3.5 0 L 7 4"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                    StrokeLineJoin="Round"
                    StrokeThickness="1.4" />
            </RepeatButton>
            <Track
                x:Name="PART_Track"
                Grid.Row="1"
                Margin="4,1"
                IsDirectionReversed="True"
                Orientation="Vertical">
                <Track.DecreaseRepeatButton>
                    <RepeatButton
                        Command="{x:Static ScrollBar.PageUpCommand}"
                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                        Style="{StaticResource ScrollBarPageButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb
                        Width="6"
                        MinHeight="28"
                        Style="{StaticResource ScrollBarThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton
                        Command="{x:Static ScrollBar.PageDownCommand}"
                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                        Style="{StaticResource ScrollBarPageButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
            <RepeatButton
                Grid.Row="2"
                Command="{x:Static ScrollBar.LineDownCommand}"
                CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                Style="{StaticResource ScrollBarLineButtonStyle}">
                <Path
                    Width="7"
                    Height="4"
                    Data="M 0 0 L 3.5 4 L 7 0"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                    StrokeLineJoin="Round"
                    StrokeThickness="1.4" />
            </RepeatButton>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="HorizontalAppScrollBarTemplate" TargetType="ScrollBar">
        <Grid Height="14" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
            </Grid.ColumnDefinitions>
            <RepeatButton
                Grid.Column="0"
                Command="{x:Static ScrollBar.LineLeftCommand}"
                CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                Style="{StaticResource ScrollBarLineButtonStyle}">
                <Path
                    Width="4"
                    Height="7"
                    Data="M 4 0 L 0 3.5 L 4 7"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                    StrokeLineJoin="Round"
                    StrokeThickness="1.4" />
            </RepeatButton>
            <Track
                x:Name="PART_Track"
                Grid.Column="1"
                Margin="1,4"
                IsDirectionReversed="False"
                Orientation="Horizontal">
                <Track.DecreaseRepeatButton>
                    <RepeatButton
                        Command="{x:Static ScrollBar.PageLeftCommand}"
                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                        Style="{StaticResource ScrollBarPageButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb
                        Height="6"
                        MinWidth="28"
                        Style="{StaticResource ScrollBarThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton
                        Command="{x:Static ScrollBar.PageRightCommand}"
                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                        Style="{StaticResource ScrollBarPageButtonStyle}" />
                </Track.IncreaseRepeatButton>
            </Track>
            <RepeatButton
                Grid.Column="2"
                Command="{x:Static ScrollBar.LineRightCommand}"
                CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                Style="{StaticResource ScrollBarLineButtonStyle}">
                <Path
                    Width="4"
                    Height="7"
                    Data="M 0 0 L 4 3.5 L 0 7"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                    StrokeLineJoin="Round"
                    StrokeThickness="1.4" />
            </RepeatButton>
        </Grid>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="14" />
        <Setter Property="MinWidth" Value="14" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template" Value="{StaticResource VerticalAppScrollBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Height" Value="14" />
                <Setter Property="MinHeight" Value="14" />
                <Setter Property="Template" Value="{StaticResource HorizontalAppScrollBarTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AppBarActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppBarForegroundBrush}" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonPressedBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WindowControlButtonStyle" TargetType="Button" BasedOn="{StaticResource AppBarActionButton}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style x:Key="WindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Height" Value="52" />
        <Setter Property="Margin" Value="20,4,16,4" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource SelectedBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AppTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Height" Value="44" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="8" />
        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}" />

    <Style x:Key="AppComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
        <Setter Property="Height" Value="44" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
        <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="8" />
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource AppComboBoxStyle}" />

    <Style x:Key="AppCompactComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource AppComboBoxStyle}">
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="AppComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Height" Value="38" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Margin" Value="4,2" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border
                        x:Name="ItemSurface"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="7"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentStringFormat="{TemplateBinding ContentStringFormat}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter
                                TargetName="ItemSurface"
                                Property="Background"
                                Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter
                                TargetName="ItemSurface"
                                Property="Background"
                                Value="{DynamicResource SelectedBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource AppComboBoxItemStyle}" />

    <Style TargetType="ListView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
    </Style>

    <Style TargetType="TreeView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource PanelBorderBrush}" />
    </Style>

    <Style x:Key="AppMenuStyle" TargetType="Menu" BasedOn="{StaticResource MaterialDesignMenu}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
    </Style>

    <Style TargetType="Menu" BasedOn="{StaticResource AppMenuStyle}" />

    <Style x:Key="AppMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource MaterialDesignMenuItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter
            Property="materialDesign:MenuItemAssist.HighlightedBackground"
            Value="{DynamicResource HoverBrush}" />
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
            </Trigger>
            <Trigger Property="IsSubmenuOpen" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
                <Setter Property="Opacity" Value="0.62" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="MenuItem" BasedOn="{StaticResource AppMenuItemStyle}" />

    <Style TargetType="ContextMenu" BasedOn="{StaticResource MaterialDesignContextMenu}">
        <Setter Property="Background" Value="{DynamicResource PopupBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
    </Style>

    <Style x:Key="LogConsoleStyle" TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}">
        <Setter Property="Height" Value="Auto" />
        <Setter Property="MinHeight" Value="84" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Background" Value="{DynamicResource SoftAccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="WorkspaceTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="46" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <UniformGrid
                            Grid.Row="0"
                            HorizontalAlignment="Stretch"
                            IsItemsHost="True"
                            Rows="1" />
                        <ContentPresenter
                            x:Name="PART_SelectedContentHost"
                            Grid.Row="1"
                            ContentSource="SelectedContent"
                            KeyboardNavigation.DirectionalNavigation="Contained"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WorkspaceTabItemStyle" TargetType="TabItem">
        <Setter Property="Height" Value="46" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border
                        x:Name="TabRoot"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ContentSource="Header"
                            RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
                            <Setter TargetName="TabRoot" Property="Background" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="TabRoot" Property="Background" Value="Transparent" />
                            <Setter TargetName="TabRoot" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="TabRoot" Property="BorderThickness" Value="0,0,0,2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SummaryLabelText" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>

    <Style x:Key="SummaryValueText" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
    </Style>

    <Style x:Key="ResourceListItemStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="materialDesign:ListBoxItemAssist.CornerRadius" Value="8" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource SelectedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
</ResourceDictionary>
