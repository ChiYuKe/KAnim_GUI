<Window
    x:Class="KAnimGui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:windows="clr-namespace:KAnimGui.Windows"
    Title="KAnim Studio"
    Width="1388"
    Height="848"
    MinWidth="1148"
    MinHeight="748"
    AllowsTransparency="True"
    AllowDrop="True"
    Background="Transparent"
    FontFamily="{DynamicResource AppFontFamily}"
    ResizeMode="CanResize"
    SnapsToDevicePixels="True"
    StateChanged="Window_StateChanged"
    TextElement.Foreground="{DynamicResource PanelTitleBrush}"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="64"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="16"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Border
            x:Name="WindowShadow"
            Margin="14"
            Background="{DynamicResource AppBarBrush}"
            CornerRadius="12"
            IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="26"
                    Color="#000000"
                    Opacity="0.30"
                    ShadowDepth="4" />
            </Border.Effect>
        </Border>

    <Border
        x:Name="WindowSurface"
        Margin="14"
        Background="{DynamicResource WorkspaceBackgroundBrush}"
        BorderBrush="Transparent"
        BorderThickness="0"
        CornerRadius="12"
        SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Custom title bar  -->
            <Border
                x:Name="TitleBarSurface"
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{DynamicResource AppBarBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                CornerRadius="12,12,0,0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="26,0,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Viewbox
                            Width="28"
                            Height="32"
                            Margin="0,0,16,0">
                            <Canvas Width="28" Height="34">
                                <Path
                                    Data="M 2,2 L 8,2 L 8,32 L 2,32 Z"
                                    Fill="{DynamicResource AccentBrush}" />
                                <Path
                                    Data="M 8,16 L 21,2 L 28,2 L 14,17 Z"
                                    Fill="{DynamicResource AccentBrush}" />
                                <Path
                                    Data="M 12,18 L 28,32 L 20,32 L 8,21 Z"
                                    Fill="{DynamicResource AccentBrush}" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AppBarForegroundBrush}"
                            Text="KAnim Studio" />
                        <TextBlock
                            Margin="14,2,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource MutedTextBrush}"
                            Text="动画资源工作台" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            x:Name="GithubButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="GithubButton_Click"
                            Style="{StaticResource AppBarActionButton}"
                            ToolTip="项目主页">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Kind="Github" />
                        </Button>
                        <Button
                            x:Name="HelpButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="HelpButton_Click"
                            Style="{StaticResource AppBarActionButton}"
                            ToolTip="帮助">
                            <materialDesign:PackIcon
                                Width="19"
                                Height="19"
                                Kind="HelpCircleOutline" />
                        </Button>
                        <Button
                            x:Name="PinButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="PinButton_Click"
                            Style="{StaticResource AppBarActionButton}"
                            ToolTip="窗口置顶">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Kind="Pin" />
                        </Button>
                        <Button
                            x:Name="SettingsButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="SettingsButton_Click"
                            Style="{StaticResource AppBarActionButton}"
                            ToolTip="设置">
                            <materialDesign:PackIcon
                                Width="19"
                                Height="19"
                                Kind="CogOutline" />
                        </Button>
                        <Border
                            Width="1"
                            Height="22"
                            Margin="10,0"
                            Background="{DynamicResource PanelBorderBrush}" />
                        <Button
                            x:Name="MinimizeButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MinimizeWindow_Click"
                            Style="{StaticResource WindowControlButtonStyle}"
                            ToolTip="最小化">
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Kind="WindowMinimize" />
                        </Button>
                        <Button
                            x:Name="MaximizeButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MaximizeWindow_Click"
                            Style="{StaticResource WindowControlButtonStyle}"
                            ToolTip="最大化">
                            <materialDesign:PackIcon
                                Width="15"
                                Height="15"
                                Kind="WindowMaximize" />
                        </Button>
                        <Button
                            x:Name="CloseButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="CloseWindow_Click"
                            Style="{StaticResource WindowCloseButtonStyle}"
                            ToolTip="关闭">
                            <materialDesign:PackIcon
                                Width="17"
                                Height="17"
                                Kind="Close" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Navigation rail  -->
            <Border
                Grid.Row="1"
                Grid.Column="0"
                Background="{DynamicResource AppBarBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button
                        x:Name="ConversionNavButton"
                        Grid.Row="0"
                        Margin="20,36,16,4"
                        Background="{DynamicResource SelectedBrush}"
                        Click="ConversionNavButton_Click"
                        Foreground="{DynamicResource AccentBrush}"
                        Style="{StaticResource NavButtonStyle}"
                        ToolTip="返回转换工作台">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Kind="SwapHorizontal" />
                            <TextBlock
                                Margin="13,0,0,0"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="转换" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="PreviewNavButton"
                        Grid.Row="1"
                        Click="PreviewNavButton_Click"
                        Style="{StaticResource NavButtonStyle}"
                        ToolTip="打开预览器">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Kind="PlayBoxOutline" />
                            <TextBlock
                                Margin="13,0,0,0"
                                VerticalAlignment="Center"
                                Text="预览" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="OniBridgeButton"
                        Grid.Row="2"
                        Click="ResourceBridgeNavButton_Click"
                        Style="{StaticResource NavButtonStyle}"
                        ToolTip="连接资源桥">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Kind="AccessPointNetwork" />
                            <TextBlock
                                Margin="13,0,0,0"
                                VerticalAlignment="Center"
                                Text="资源桥" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="LogNavButton"
                        Grid.Row="3"
                        Click="LogNavButton_Click"
                        Style="{StaticResource NavButtonStyle}"
                        ToolTip="查看转换日志">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Kind="ConsoleLine" />
                            <TextBlock
                                Margin="13,0,0,0"
                                VerticalAlignment="Center"
                                Text="日志" />
                        </StackPanel>
                    </Button>

                    <Border
                        Grid.Row="5"
                        Margin="20,0,16,8"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="0,1,0,0">
                        <Button
                            x:Name="SettingsNavButton"
                            Margin="0,12,0,0"
                            Click="SettingsButton_Click"
                            Style="{StaticResource NavButtonStyle}"
                            ToolTip="设置">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="20"
                                    Height="20"
                                    Kind="CogOutline" />
                                <TextBlock
                                    Margin="13,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="设置" />
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <!--  Main workspace  -->
            <Grid
                x:Name="ConversionWorkspace"
                Grid.Row="1"
                Grid.Column="1"
                MaxWidth="1240"
                Margin="32,20,32,12"
                HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="350" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.Column="0">
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource PageTitleText}"
                            Text="转换工作台" />
                        <TextBlock
                            Margin="0,5,0,0"
                            Style="{StaticResource SupportingText}"
                            Text="准备资源、检查输入并导出可用动画文件。" />
                    </StackPanel>
                </Grid>

                <TabControl
                    x:Name="MainTabControl"
                    Grid.Row="1"
                    Grid.Column="0"
                    ItemContainerStyle="{StaticResource WorkspaceTabItemStyle}"
                    Style="{StaticResource WorkspaceTabControlStyle}">

                    <!--  KAnim to SCML  -->
                    <TabItem
                        x:Name="KanimToScmlTab"
                        Header="KAnim → SCML">
                        <ScrollViewer
                            Padding="0,12,0,4"
                            HorizontalScrollBarVisibility="Disabled"
                            TextElement.Foreground="{DynamicResource PanelTitleBrush}"
                            VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Grid.Row="0"
                                    Padding="18,16"
                                    Style="{StaticResource WorkspaceCardStyle}">
                                    <StackPanel>
                                        <TextBlock
                                            Style="{StaticResource SectionTitleText}"
                                            Text="添加 KAnim 文件" />
                                        <TextBlock
                                            Margin="0,5,0,0"
                                            Style="{StaticResource SupportingText}"
                                            Text="拖入 PNG、_anim.bytes、_build.bytes，或选择文件。" />

                                        <Grid Margin="0,14,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="44" />
                                                <RowDefinition Height="10" />
                                                <RowDefinition Height="44" />
                                                <RowDefinition Height="10" />
                                                <RowDefinition Height="44" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="104" />
                                            </Grid.ColumnDefinitions>

                                            <Border
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                Background="{DynamicResource SelectedBrush}"
                                                CornerRadius="8">
                                                <materialDesign:PackIcon
                                                    Width="22"
                                                    Height="22"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource AccentBrush}"
                                                    Kind="FileImageOutline" />
                                            </Border>
                                            <TextBox
                                                x:Name="PngPathTextBox"
                                                Grid.Row="0"
                                                Grid.Column="2"
                                                materialDesign:HintAssist.Hint="PNG 纹理文件"
                                                Style="{StaticResource AppTextBoxStyle}"
                                                Text="{Binding PngPath, UpdateSourceTrigger=PropertyChanged}"
                                                ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                            <Button
                                                x:Name="BrowsePngButton"
                                                Grid.Row="0"
                                                Grid.Column="4"
                                                Click="Browse_Click"
                                                Content="浏览"
                                                Style="{StaticResource BrowseActionButton}" />

                                            <Border
                                                Grid.Row="2"
                                                Grid.Column="0"
                                                Background="{DynamicResource SelectedBrush}"
                                                CornerRadius="8">
                                                <materialDesign:PackIcon
                                                    Width="22"
                                                    Height="22"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource AccentBrush}"
                                                    Kind="FileDocumentOutline" />
                                            </Border>
                                            <TextBox
                                                x:Name="AnimPathTextBox"
                                                Grid.Row="2"
                                                Grid.Column="2"
                                                materialDesign:HintAssist.Hint="_anim.bytes 文件"
                                                Style="{StaticResource AppTextBoxStyle}"
                                                Text="{Binding AnimPath, UpdateSourceTrigger=PropertyChanged}"
                                                ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                            <Button
                                                x:Name="BrowseAnimButton"
                                                Grid.Row="2"
                                                Grid.Column="4"
                                                Click="Browse_Click"
                                                Content="浏览"
                                                Style="{StaticResource BrowseActionButton}" />

                                            <Border
                                                Grid.Row="4"
                                                Grid.Column="0"
                                                Background="{DynamicResource SelectedBrush}"
                                                CornerRadius="8">
                                                <materialDesign:PackIcon
                                                    Width="22"
                                                    Height="22"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource AccentBrush}"
                                                    Kind="FileTreeOutline" />
                                            </Border>
                                            <TextBox
                                                x:Name="BuildPathTextBox"
                                                Grid.Row="4"
                                                Grid.Column="2"
                                                materialDesign:HintAssist.Hint="_build.bytes 文件"
                                                Style="{StaticResource AppTextBoxStyle}"
                                                Text="{Binding BuildPath, UpdateSourceTrigger=PropertyChanged}"
                                                ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                            <Button
                                                x:Name="BrowseBuildButton"
                                                Grid.Row="4"
                                                Grid.Column="4"
                                                Click="Browse_Click"
                                                Content="浏览"
                                                Style="{StaticResource BrowseActionButton}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Margin="0,10,0,0"
                                    Padding="14"
                                    Style="{StaticResource WorkspaceCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="104" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Kind="FolderOutline" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="输出到" />
                                        <TextBox
                                            x:Name="OutputDirTextBox"
                                            Grid.Column="4"
                                            Style="{StaticResource AppTextBoxStyle}"
                                            Text="{Binding KanimOutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                        <Button
                                            x:Name="BrowseOutputDirButton"
                                            Grid.Column="6"
                                            Click="Browse_Click"
                                            Content="更改"
                                            Style="{StaticResource BrowseActionButton}" />
                                    </Grid>
                                </Border>

                                <Border
                                    x:Name="KanimOptionsPanel"
                                    Grid.Row="2"
                                    Margin="0,10,0,0"
                                    Padding="16,12"
                                    Style="{StaticResource WorkspaceCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Kind="TuneVariant" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="转换选项" />
                                        <WrapPanel
                                            Grid.Column="4"
                                            VerticalAlignment="Center">
                                        <CheckBox
                                            x:Name="StrictModeCheckBox"
                                            Margin="0,0,24,0"
                                            Content="严格模式"
                                            IsChecked="{Binding StrictMode}" />
                                        <CheckBox
                                            x:Name="StrictOrderCheckBox"
                                            Content="严格文件顺序"
                                            IsChecked="{Binding StrictOrder}" />
                                        </WrapPanel>
                                    </Grid>
                                </Border>

                                <StackPanel
                                    Grid.Row="3"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                                    <Button
                                        x:Name="BatchConvertButton"
                                        Width="112"
                                        Margin="0,0,10,0"
                                        Click="BatchConvertButton_Click"
                                        Content="批量转换"
                                        Style="{StaticResource SecondaryActionButton}" />
                                    <Button
                                        x:Name="ClearButton"
                                        Width="96"
                                        Margin="0,0,10,0"
                                        Click="ClearButton_Click"
                                        Content="清除"
                                        Style="{StaticResource SecondaryActionButton}" />
                                    <Button
                                        x:Name="CancelKanimButton"
                                        Width="96"
                                        Margin="0,0,10,0"
                                        Command="{Binding CancelKanimCommand}"
                                        Content="取消"
                                        Style="{StaticResource SecondaryActionButton}" />
                                    <Button
                                        x:Name="ConvertButton"
                                        Width="144"
                                        Command="{Binding ConvertKanimCommand}"
                                        Content="开始转换"
                                        Style="{StaticResource PrimaryActionButton}" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!--  SCML to KAnim  -->
                    <TabItem
                        x:Name="ScmlToKanimTab"
                        Header="SCML → KAnim">
                        <ScrollViewer
                            Padding="0,12,0,4"
                            HorizontalScrollBarVisibility="Disabled"
                            TextElement.Foreground="{DynamicResource PanelTitleBrush}"
                            VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Grid.Row="0"
                                    Padding="18,16"
                                    Style="{StaticResource WorkspaceCardStyle}">
                                    <StackPanel>
                                        <TextBlock
                                            Style="{StaticResource SectionTitleText}"
                                            Text="添加 SCML 文件" />
                                        <TextBlock
                                            Margin="0,5,0,18"
                                            Style="{StaticResource SupportingText}"
                                            Text="选择一个 SCML 文件，或直接拖入窗口。" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="104" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Grid.Column="0"
                                                Background="{DynamicResource SelectedBrush}"
                                                CornerRadius="8">
                                                <materialDesign:PackIcon
                                                    Width="22"
                                                    Height="22"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource AccentBrush}"
                                                    Kind="FileDocumentOutline" />
                                            </Border>
                                            <TextBox
                                                x:Name="ScmlPathTextBox"
                                                Grid.Column="2"
                                                materialDesign:HintAssist.Hint="SCML 文件"
                                                Style="{StaticResource AppTextBoxStyle}"
                                                Text="{Binding ScmlPath, UpdateSourceTrigger=PropertyChanged}"
                                                ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                            <Button
                                                x:Name="BrowseScmlButton"
                                                Grid.Column="4"
                                                Click="Browse_Click"
                                                Content="浏览"
                                                Style="{StaticResource BrowseActionButton}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Margin="0,10,0,0"
                                    Padding="14"
                                    Style="{StaticResource WorkspaceCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="104" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Kind="FolderOutline" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="输出到" />
                                        <TextBox
                                            x:Name="ScmlOutputDirTextBox"
                                            Grid.Column="4"
                                            Style="{StaticResource AppTextBoxStyle}"
                                            Text="{Binding ScmlOutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                        <Button
                                            x:Name="BrowseScmlOutputDirButton"
                                            Grid.Column="6"
                                            Click="Browse_Click"
                                            Content="更改"
                                            Style="{StaticResource BrowseActionButton}" />
                                    </Grid>
                                </Border>

                                <Border
                                    x:Name="ScmlOptionsPanel"
                                    Grid.Row="2"
                                    Margin="0,10,0,0"
                                    Padding="16,12"
                                    Style="{StaticResource WorkspaceCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon
                                            Width="20"
                                            Height="20"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Kind="TuneVariant" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="转换选项" />
                                        <WrapPanel
                                            Grid.Column="4"
                                            VerticalAlignment="Center">
                                        <CheckBox
                                            x:Name="InterpolateCheckBox"
                                            Margin="0,0,24,0"
                                            Content="启用插值"
                                            IsChecked="{Binding Interpolate}" />
                                        <CheckBox
                                            x:Name="DeboneCheckBox"
                                            Content="去骨骼"
                                            IsChecked="{Binding Debone}" />
                                        </WrapPanel>
                                    </Grid>
                                </Border>

                                <StackPanel
                                    Grid.Row="3"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                                    <Button
                                        x:Name="BatchConvertScmlButton"
                                        Width="112"
                                        Margin="0,0,10,0"
                                        Click="BatchConvertScmlButton_Click"
                                        Content="批量转换"
                                        Style="{StaticResource SecondaryActionButton}" />
                                    <Button
                                        x:Name="ScmlClearButton"
                                        Width="96"
                                        Margin="0,0,10,0"
                                        Click="ScmlClearButton_Click"
                                        Content="清除"
                                        Style="{StaticResource SecondaryActionButton}" />
                                    <Button
                                        x:Name="CancelScmlButton"
                                        Width="96"
                                        Margin="0,0,10,0"
                                        Command="{Binding CancelScmlCommand}"
                                        Content="取消"
                                        Style="{StaticResource SecondaryActionButton}" />
                                    <Button
                                        x:Name="ConvertScmlButton"
                                        Width="144"
                                        Command="{Binding ConvertScmlCommand}"
                                        Content="开始转换"
                                        Style="{StaticResource PrimaryActionButton}" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!--  KAnim summary  -->
                <Border
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="0,46,0,0"
                    Padding="18"
                    Style="{StaticResource WorkspaceCardStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid x:Name="KanimSummaryPanel">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedIndex, ElementName=MainTabControl}" Value="1">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="180" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Style="{StaticResource SectionTitleText}"
                                    Text="资源预览" />

                                <Border
                                    Grid.Row="2"
                                    Background="{DynamicResource PreviewBackgroundBrush}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="9">
                                    <Grid>
                                        <Border
                                            Height="1"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource GridLineBrush}" />
                                        <Border
                                            Width="1"
                                            HorizontalAlignment="Center"
                                            Background="{DynamicResource GridLineBrush}" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <materialDesign:PackIcon
                                                Width="46"
                                                Height="46"
                                                HorizontalAlignment="Center"
                                                Foreground="{DynamicResource PreviewPlaceholderBrush}"
                                                Kind="ImageMultipleOutline" />
                                            <TextBlock
                                                Margin="0,9,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="13"
                                                Foreground="{DynamicResource MutedTextBrush}"
                                                Text="当前未选择任何资源" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="4">
                                    <Border
                                        Height="44"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Style="{StaticResource SummaryLabelText}" Text="待转换资源" />
                                            <TextBlock Style="{StaticResource SummaryValueText}" Text="PNG + Anim + Build" />
                                        </Grid>
                                    </Border>
                                    <Border
                                        Height="44"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Style="{StaticResource SummaryLabelText}" Text="转换方向" />
                                            <TextBlock Style="{StaticResource SummaryValueText}" Text="KAnim → SCML" />
                                        </Grid>
                                    </Border>
                                    <Border
                                        Height="44"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Style="{StaticResource SummaryLabelText}" Text="输入" />
                                            <TextBlock Style="{StaticResource SummaryValueText}" Text="3 个文件" />
                                        </Grid>
                                    </Border>
                                    <Border
                                        Height="44"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Style="{StaticResource SummaryLabelText}" Text="输出" />
                                            <TextBlock Style="{StaticResource SummaryValueText}" Text="SCML + 纹理" />
                                        </Grid>
                                    </Border>
                                    <Border Height="44">
                                        <Grid>
                                            <TextBlock Style="{StaticResource SummaryLabelText}" Text="状态" />
                                            <Border
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Padding="10,6"
                                                Background="{DynamicResource SelectedBrush}"
                                                CornerRadius="8">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse
                                                        Width="7"
                                                        Height="7"
                                                        Margin="0,0,7,0"
                                                        VerticalAlignment="Center"
                                                        Fill="{DynamicResource StatusBrush}" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource StatusBrush}"
                                                        Text="准备就绪" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid x:Name="ScmlSummaryPanel">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedIndex, ElementName=MainTabControl}" Value="1">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="180" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Style="{StaticResource SectionTitleText}"
                                    Text="KAnim 导出" />
                                <Border
                                    Grid.Row="2"
                                    Background="{DynamicResource PreviewBackgroundBrush}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="9">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <materialDesign:PackIcon
                                            Width="46"
                                            Height="46"
                                            HorizontalAlignment="Center"
                                            Foreground="{DynamicResource PreviewPlaceholderBrush}"
                                            Kind="FileExportOutline" />
                                        <TextBlock
                                            Margin="0,9,0,0"
                                            HorizontalAlignment="Center"
                                            FontSize="13"
                                            Foreground="{DynamicResource MutedTextBrush}"
                                            Text="选择 SCML 后生成 KAnim 资源" />
                                    </StackPanel>
                                </Border>
                                <StackPanel Grid.Row="4">
                                    <Border
                                        Height="44"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Style="{StaticResource SummaryLabelText}" Text="待转换资源" />
                                            <TextBlock Style="{StaticResource SummaryValueText}" Text="SCML 文件" />
                                        </Grid>
                                    </Border>
                                    <Border
                                        Height="44"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Style="{StaticResource SummaryLabelText}" Text="转换方向" />
                                            <TextBlock Style="{StaticResource SummaryValueText}" Text="SCML → KAnim" />
                                        </Grid>
                                    </Border>
                                    <Border
                                        Height="44"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Style="{StaticResource SummaryLabelText}" Text="输入" />
                                            <TextBlock Style="{StaticResource SummaryValueText}" Text="1 个文件" />
                                        </Grid>
                                    </Border>
                                    <Border
                                        Height="44"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Style="{StaticResource SummaryLabelText}" Text="输出" />
                                            <TextBlock Style="{StaticResource SummaryValueText}" Text="PNG + Anim + Build" />
                                        </Grid>
                                    </Border>
                                    <Border Height="44">
                                        <Grid>
                                            <TextBlock Style="{StaticResource SummaryLabelText}" Text="状态" />
                                            <Border
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Padding="10,6"
                                                Background="{DynamicResource SelectedBrush}"
                                                CornerRadius="8">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse
                                                        Width="7"
                                                        Height="7"
                                                        Margin="0,0,7,0"
                                                        VerticalAlignment="Center"
                                                        Fill="{DynamicResource StatusBrush}" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource StatusBrush}"
                                                        Text="准备就绪" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!--  Dedicated log workspace  -->
            <Grid
                x:Name="LogWorkspace"
                Grid.Row="1"
                Grid.Column="1"
                MaxWidth="1240"
                Margin="32,20,32,12"
                HorizontalAlignment="Stretch"
                Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource PageTitleText}"
                            Text="日志控制台" />
                        <TextBlock
                            Margin="0,5,0,0"
                            Style="{StaticResource SupportingText}"
                            Text="查看转换过程、警告和错误信息。" />
                    </StackPanel>
                    <Button
                        x:Name="ClearActiveLogButton"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="ClearActiveLogButton_Click"
                        Style="{StaticResource ToolbarActionButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="17"
                                Height="17"
                                Margin="0,0,7,0"
                                Kind="DeleteSweepOutline" />
                            <TextBlock VerticalAlignment="Center" Text="清空日志" />
                        </StackPanel>
                    </Button>
                </Grid>

                <TabControl
                    x:Name="LogTabControl"
                    Grid.Row="1"
                    ItemContainerStyle="{StaticResource WorkspaceTabItemStyle}"
                    Style="{StaticResource WorkspaceTabControlStyle}">
                    <TabItem Header="KAnim → SCML">
                        <Border
                            Margin="0,12,0,0"
                            Padding="18"
                            Style="{StaticResource WorkspaceCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <TextBlock
                                        Style="{StaticResource SectionTitleText}"
                                        Text="KAnim → SCML 日志" />
                                    <StackPanel
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Ellipse
                                            Width="7"
                                            Height="7"
                                            Margin="0,0,7,0"
                                            Fill="{DynamicResource StatusBrush}" />
                                        <TextBlock
                                            Style="{StaticResource SupportingText}"
                                            Text="实时更新" />
                                    </StackPanel>
                                </Grid>
                                <TextBox
                                    x:Name="LogTextBox"
                                    Grid.Row="2"
                                    HorizontalScrollBarVisibility="Auto"
                                    Style="{StaticResource LogConsoleStyle}"
                                    TextWrapping="NoWrap" />
                                <TextBlock
                                    Grid.Row="2"
                                    Margin="16,14"
                                    VerticalAlignment="Top"
                                    IsHitTestVisible="False"
                                    Text="暂无日志。开始转换后，输出会实时显示在这里。">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SupportingText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=LogTextBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </TabItem>

                    <TabItem Header="SCML → KAnim">
                        <Border
                            Margin="0,12,0,0"
                            Padding="18"
                            Style="{StaticResource WorkspaceCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <TextBlock
                                        Style="{StaticResource SectionTitleText}"
                                        Text="SCML → KAnim 日志" />
                                    <StackPanel
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Ellipse
                                            Width="7"
                                            Height="7"
                                            Margin="0,0,7,0"
                                            Fill="{DynamicResource StatusBrush}" />
                                        <TextBlock
                                            Style="{StaticResource SupportingText}"
                                            Text="实时更新" />
                                    </StackPanel>
                                </Grid>
                                <TextBox
                                    x:Name="ScmlLogTextBox"
                                    Grid.Row="2"
                                    HorizontalScrollBarVisibility="Auto"
                                    Style="{StaticResource LogConsoleStyle}"
                                    TextWrapping="NoWrap" />
                                <TextBlock
                                    Grid.Row="2"
                                    Margin="16,14"
                                    VerticalAlignment="Top"
                                    IsHitTestVisible="False"
                                    Text="暂无日志。开始转换后，输出会实时显示在这里。">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SupportingText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=ScmlLogTextBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>

            <!--  Embedded settings workspace  -->
            <windows:SettingsWorkspace
                x:Name="SettingsWorkspacePanel"
                Grid.Row="1"
                Grid.Column="1"
                Visibility="Collapsed" />

            <!--  Embedded preview and resource bridge workspaces  -->
            <ContentControl
                x:Name="PreviewWorkspaceHost"
                Grid.Row="1"
                Grid.Column="1"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Visibility="Collapsed" />

            <ContentControl
                x:Name="ResourceBridgeWorkspaceHost"
                Grid.Row="1"
                Grid.Column="1"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Visibility="Collapsed" />

            <!--  Footer  -->
            <Border
                x:Name="FooterSurface"
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Padding="20,0"
                Background="{DynamicResource AppBarBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12">
                <Grid>
                    <TextBlock
                        x:Name="StatusText"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource MutedTextBrush}"
                        Text="状态：内置内核就绪" />
                    <TextBlock
                        x:Name="ProgressBar"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource SubtleTextBrush}"
                        Text="KAnim GUI 1.0.2" />
                </Grid>
            </Border>
        </Grid>
    </Border>
    </Grid>
</Window>
