<Window
    x:Class="KAnimGui.Windows.OniResourceBridgeWorkspaceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="ONI 资源桥"
    Width="1280"
    Height="780"
    MinWidth="1080"
    MinHeight="650"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="ONI 资源桥" />
                <TextBlock Margin="0,4,0,0" Foreground="#FF6B2742" Text="{Binding ConnectionText}" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Margin="8,0,0,0"
                Command="{Binding RefreshCommand}"
                Content="刷新"
                MinWidth="84" />
            <Button
                Grid.Column="2"
                Margin="8,0,0,0"
                Command="{Binding CancelCommand}"
                Content="取消"
                IsEnabled="{Binding IsBusy}"
                MinWidth="84" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,12,0" Padding="14" BorderBrush="#FFE7CED8" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="筛选" />
                    <TextBox Margin="0,12,0,0" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="搜索名称或 Bundle" />
                    <ComboBox Margin="0,12,0,0" SelectedIndex="0" SelectedValue="{Binding ResourceTypeFilter}" SelectedValuePath="Content">
                        <ComboBoxItem Content="KAnim" />
                        <ComboBoxItem Content="Sprite" />
                        <ComboBoxItem Content="全部" />
                    </ComboBox>
                    <CheckBox Margin="0,12,0,0" Content="仅显示收藏" IsChecked="{Binding FavoritesOnly}" />
                    <TextBlock Margin="0,18,0,0" FontWeight="SemiBold" Text="KAnim 导出布局" />
                    <ComboBox Margin="0,6,0,0" ItemsSource="{Binding ExportLayoutOptions}" SelectedItem="{Binding ExportLayoutText, UpdateSourceTrigger=PropertyChanged}" />
                    <Separator Margin="0,18,0,12" />
                    <TextBlock FontWeight="SemiBold" Text="导出目录" />
                    <TextBlock Margin="0,6,0,0" Text="{Binding ExportDirectory}" TextWrapping="Wrap" />
                    <Button Margin="0,12,0,0" Click="OpenExportFolder_Click" Content="打开导出目录" />
                </StackPanel>
            </Border>

            <ListView
                x:Name="ResourceListView"
                Grid.Column="1"
                BorderBrush="#FFE7CED8"
                BorderThickness="1"
                ItemsSource="{Binding FilteredResources}"
                SelectedItem="{Binding SelectedResource, Mode=TwoWay}"
                SelectionChanged="ResourceListView_SelectionChanged"
                SelectionMode="Extended"
                ScrollViewer.CanContentScroll="True"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="70" Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="58" Height="58" Background="#FFF4EEF1" BorderBrush="#FFE7CED8" BorderThickness="1">
                                <Grid>
                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF9E7A86" Text="无图">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="8,0,0,0" Foreground="#FFD18B00" Text="{Binding FavoriteGlyph}" />
                                </StackPanel>
                                <TextBlock Margin="0,4,0,0" Foreground="#FF6B2742" Text="{Binding SourceLabel}" />
                                <TextBlock FontSize="11" Foreground="#FF9E6B7C" Text="{Binding ImportStatus}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#FF6B2742" Text="{Binding SummaryText}" TextWrapping="Wrap" />
                            <Button
                                Grid.Column="3"
                                Margin="8,0,0,0"
                                Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Content="收藏"
                                VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Grid.Column="2" Margin="12,0,0,0" Padding="16" BorderBrush="#FFE7CED8" BorderThickness="1" CornerRadius="8">
                <StackPanel DataContext="{Binding SelectedResource}">
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="资源详情" />
                    <Image Height="180" Margin="0,14,0,10" Source="{Binding Thumbnail}" Stretch="Uniform" />
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0" Text="{Binding ResourceTypeLabel}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding SourceLabel}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding SummaryText}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0" Foreground="#FF6B2742" Text="{Binding ImportStatus}" />
                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="标签" />
                    <TextBox Margin="0,4,0,0" Text="{Binding DataContext.TagEditText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="用逗号分隔" />
                    <Button Margin="0,6,0,0" Command="{Binding DataContext.SaveTagsCommand, RelativeSource={RelativeSource AncestorType=Window}}" Content="保存标签" />
                    <Button Margin="0,16,0,0" Command="{Binding DataContext.ImportSelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}" Content="导入 / 导出选中" />
                </StackPanel>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right" Command="{Binding ExportFilteredCommand}" Content="批量导出当前结果" MinWidth="150" />
            <TextBlock VerticalAlignment="Center" Foreground="#FF6B2742" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
        </DockPanel>
    </Grid>
</Window>
