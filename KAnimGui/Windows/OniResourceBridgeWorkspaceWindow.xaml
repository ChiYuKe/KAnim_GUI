<UserControl
    x:Class="KAnimGui.Windows.OniResourceBridgeWorkspaceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="{DynamicResource WorkspaceBackgroundBrush}"
    Focusable="True"
    FontFamily="{DynamicResource AppFontFamily}"
    TextElement.Foreground="{DynamicResource PanelTitleBrush}"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="ClearType"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">
    <UserControl.Resources>
        <SolidColorBrush x:Key="AppBarBrush" Color="{DynamicResource ThemeAppBarColor}" />
        <SolidColorBrush x:Key="WorkspaceBackgroundBrush" Color="{DynamicResource ThemeWorkspaceColor}" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{DynamicResource ThemePanelColor}" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="{DynamicResource ThemePanelBorderColor}" />
        <SolidColorBrush x:Key="PanelTitleBrush" Color="{DynamicResource ThemePanelTitleColor}" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="{DynamicResource ThemeMutedColor}" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="{DynamicResource ThemeSubtleColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource ThemePrimaryColor}" />
        <SolidColorBrush x:Key="SoftAccentBrush" Color="{DynamicResource ThemeSoftAccentColor}" />
        <SolidColorBrush x:Key="PreviewBackgroundBrush" Color="{DynamicResource ThemePreviewColor}" />
        <SolidColorBrush x:Key="BridgePreviewSurfaceBrush" Color="{DynamicResource ThemeBridgePreviewSurfaceColor}" />
        <SolidColorBrush x:Key="PreviewPlaceholderBrush" Color="{DynamicResource ThemePreviewPlaceholderColor}" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <DropShadowEffect
            x:Key="BridgeSecondaryButtonShadow"
            x:Shared="False"
            BlurRadius="7"
            Color="#17343B"
            Opacity="0.09"
            ShadowDepth="1" />

        <Style x:Key="BridgeSectionTitleText" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="BridgePanelCardStyle" TargetType="Border" BasedOn="{StaticResource WorkspaceCardStyle}">
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="BridgeThumbnailFrameStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PreviewBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="BridgePreviewCanvasStyle" TargetType="Border" BasedOn="{StaticResource BridgeThumbnailFrameStyle}">
            <Setter Property="Background" Value="{StaticResource BridgePreviewSurfaceBrush}" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="BridgeSecondaryActionButton" BasedOn="{StaticResource SecondaryActionButton}" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="WorkspaceHeaderActionButton" BasedOn="{StaticResource PrimaryActionButton}" TargetType="Button">
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="OpenFolderActionButton" BasedOn="{StaticResource BridgeSecondaryActionButton}" TargetType="Button">
            <Setter Property="Width" Value="160" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="WorkspaceHeaderPrimaryButton" BasedOn="{StaticResource PrimaryActionButton}" TargetType="Button">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="16,0" />
        </Style>

        <Style x:Key="ResourceListItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource PanelTitleBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource WorkspaceBackgroundBrush}">
        <Border
            Height="72"
            Padding="12,0"
            Background="{StaticResource AppBarBrush}"
            DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppBarForegroundBrush}"
                        Text="ONI 资源桥" />
                    <TextBlock
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource MutedTextBrush}"
                        Text="{Binding ConnectionText}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button
                        Command="{Binding RefreshCommand}"
                        Content="刷新资源"
                        Style="{StaticResource WorkspaceHeaderPrimaryButton}" />
                    <Button
                        Command="{Binding CancelCommand}"
                        Content="取消"
                        IsEnabled="{Binding IsBusy}"
                        Style="{StaticResource WorkspaceHeaderActionButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="10,12,10,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Margin="0,0,10,0"
                    Padding="14"
                    Style="{StaticResource BridgePanelCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource BridgeSectionTitleText}" Text="资源筛选" />
                        <TextBox
                            Margin="0,12,0,0"
                            Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="搜索名称或 Bundle" />
                        <ComboBox
                            ItemContainerStyle="{StaticResource AppComboBoxItemStyle}"
                            Margin="0,12,0,0"
                            SelectedIndex="0"
                            SelectedValue="{Binding ResourceTypeFilter}"
                            SelectedValuePath="Content">
                            <ComboBoxItem Content="KAnim" Style="{StaticResource AppComboBoxItemStyle}" />
                            <ComboBoxItem Content="Sprite" Style="{StaticResource AppComboBoxItemStyle}" />
                            <ComboBoxItem Content="全部" Style="{StaticResource AppComboBoxItemStyle}" />
                        </ComboBox>
                        <TextBlock
                            Margin="0,12,0,0"
                            Foreground="{StaticResource SubtleTextBrush}"
                            Text="{Binding FilterSummaryText}" />

                        <Separator Margin="0,18,0,12" Background="{StaticResource PanelBorderBrush}" />
                        <TextBlock Style="{StaticResource BridgeSectionTitleText}" Text="导出布局" />
                        <ComboBox
                            Margin="0,6,0,0"
                            ItemContainerStyle="{StaticResource AppComboBoxItemStyle}"
                            ItemsSource="{Binding ExportLayoutOptions}"
                            SelectedItem="{Binding ExportLayoutText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource SubtleTextBrush}"
                            Text="{Binding ExportLayoutDescription}"
                            TextWrapping="Wrap" />

                        <Separator Margin="0,18,0,12" Background="{StaticResource PanelBorderBrush}" />
                        <TextBlock Style="{StaticResource BridgeSectionTitleText}" Text="导出目录" />
                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource SubtleTextBrush}"
                            Text="{Binding ExportDirectory}"
                            TextWrapping="Wrap" />
                        <Button
                            Margin="0,12,0,0"
                            Click="OpenExportFolder_Click"
                            Style="{StaticResource OpenFolderActionButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Kind="FolderOpenOutline" />
                                <TextBlock VerticalAlignment="Center" Text="打开导出目录" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="6"
                    Style="{StaticResource BridgePanelCardStyle}">
                    <DockPanel>
                        <Grid Margin="8,4,8,8" DockPanel.Dock="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource BridgeSectionTitleText}" Text="在线资源" />
                                <TextBlock
                                    Margin="0,3,0,0"
                                    Foreground="{StaticResource SubtleTextBrush}"
                                    Text="缩略图随列表滚动按需加载，选中资源会优先显示。" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource MutedTextBrush}"
                                Text="支持多选后批量导出" />
                        </Grid>

                        <ListView
                            x:Name="ResourceListView"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource ResourceListItemStyle}"
                            ItemsSource="{Binding FilteredResources}"
                            SelectedItem="{Binding SelectedResource, Mode=TwoWay}"
                            SelectionChanged="ResourceListView_SelectionChanged"
                            Loaded="ResourceListView_Loaded"
                            ScrollViewer.ScrollChanged="ResourceListView_ScrollChanged"
                            SelectionMode="Extended"
                            ScrollViewer.CanContentScroll="True"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="82" Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="72"
                                            Height="72"
                                            Style="{StaticResource BridgeThumbnailFrameStyle}">
                                            <Grid>
                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource PreviewPlaceholderBrush}"
                                                    Text="{Binding ThumbnailStatusText}"
                                                    TextAlignment="Center"
                                                    TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasPreviewLoaded}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{Binding SourceLabel}" />
                                                <TextBlock Margin="10,0,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="{Binding ResourceTypeLabel}" />
                                            </StackPanel>
                                            <TextBlock
                                                Margin="0,3,0,0"
                                                Foreground="{StaticResource SubtleTextBrush}"
                                                Text="{Binding ExportStatus}" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="2"
                                            Margin="8,0,8,0"
                                            Click="ResourceRowAction_Click"
                                            Content="{Binding RowActionText}"
                                            IsEnabled="{Binding CanExport}"
                                            Style="{StaticResource CompactActionButton}"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Padding="16"
                    Style="{StaticResource BridgePanelCardStyle}">
                    <Grid DataContext="{Binding SelectedResource}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource BridgeSectionTitleText}" Text="资源预览" />
                        <Border
                            Grid.Row="1"
                            Height="230"
                            Margin="0,14,0,10"
                            Style="{StaticResource BridgePreviewCanvasStyle}">
                            <Grid>
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource PreviewPlaceholderBrush}"
                                    Text="{Binding ThumbnailStatusText}"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPreviewLoaded}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="2">
                            <TextBlock FontSize="17" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{Binding ResourceTypeLabel}" />
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{Binding SourceLabel}" />
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{Binding SummaryText}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="{Binding BundleText}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,12,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="选中资源后可查看在线缩略图并直接导出。" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            Grid.Row="3"
                            Command="{Binding DataContext.ExportResourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Content="导出当前资源"
                            Style="{StaticResource PrimaryActionButton}" />
                    </Grid>
                </Border>
            </Grid>

            <DockPanel Grid.Row="1" Margin="0,10,0,0">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ProgressBar
                        Width="120"
                        Height="6"
                        Margin="0,0,8,0"
                        Maximum="100"
                        Minimum="0"
                        Value="{Binding ExportProgress}"
                        Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibility}}"
                        VerticalAlignment="Center" />
                    <Button
                        Command="{Binding ExportFilteredCommand}"
                        Content="{Binding ExportButtonText}"
                        Style="{StaticResource PrimaryActionButton}" />
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource PanelTitleBrush}" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        Margin="0,2,0,0"
                        Foreground="{DynamicResource MutedTextBrush}"
                        Text="{Binding ExportProgressText}"
                        TextTrimming="CharacterEllipsis"
                        Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibility}}" />
                    <TextBlock
                        Margin="0,2,0,0"
                        Foreground="{DynamicResource MutedTextBrush}"
                        Text="{Binding ExportResultText}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
