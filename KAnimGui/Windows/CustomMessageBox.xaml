<Window
    x:Class="KAnimGui.Windows.CustomMessageBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="KAnim Studio"
    Width="460"
    MinHeight="230"
    MaxHeight="480"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="{DynamicResource AppFontFamily}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    TextElement.Foreground="{DynamicResource PanelTitleBrush}"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="ClearType"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">
    <Border
        Margin="18"
        Background="{DynamicResource PanelBackgroundBrush}"
        CornerRadius="14"
        Effect="{StaticResource WorkspaceCardShadow}"
        SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Margin="20,0,12,0"
                Background="Transparent"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="36"
                    Height="36"
                    VerticalAlignment="Center"
                    Background="{DynamicResource AccentBrush}"
                    CornerRadius="18">
                    <materialDesign:PackIcon
                        x:Name="IconPack"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource AccentTextBrush}"
                        Kind="InformationOutline" />
                </Border>

                <TextBlock
                    x:Name="TitleTextBlock"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource PanelTitleBrush}"
                    Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                    TextTrimming="CharacterEllipsis" />

                <Button
                    Grid.Column="3"
                    Click="CloseButton_Click"
                    Style="{StaticResource WindowCloseButtonStyle}"
                    ToolTip="关闭">
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Kind="Close" />
                </Button>
            </Grid>

            <Border
                Grid.Row="1"
                Margin="20,0"
                Padding="16,14"
                Background="{DynamicResource WorkspaceBackgroundBrush}"
                CornerRadius="10">
                <ScrollViewer
                    MaxHeight="240"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <TextBlock
                        x:Name="MessageTextBlock"
                        FontSize="14"
                        Foreground="{DynamicResource MutedTextBrush}"
                        LineHeight="22"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>

            <StackPanel
                Grid.Row="2"
                Margin="20,16,20,20"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    x:Name="SecondaryButton"
                    MinWidth="96"
                    Margin="0,0,10,0"
                    Click="SecondaryButton_Click"
                    Content="否"
                    Style="{StaticResource DialogActionButton}"
                    Visibility="Collapsed" />
                <Button
                    x:Name="ConfirmButton"
                    MinWidth="96"
                    Click="ConfirmButton_Click"
                    Content="确定"
                    Style="{StaticResource DialogPrimaryButton}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
