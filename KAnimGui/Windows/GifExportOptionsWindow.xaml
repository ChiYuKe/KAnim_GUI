<Window
    x:Class="KAnimGui.Windows.GifExportOptionsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="导出 GIF"
    Width="380"
    Height="300"
    FontFamily="{DynamicResource AppFontFamily}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Border Padding="20" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,16"
                FontSize="18"
                FontWeight="SemiBold"
                Text="GIF 导出设置" />

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="帧率 (FPS)" />
                <TextBox x:Name="FrameRateTextBox" Grid.Column="1" Padding="6,4" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="输出宽度" />
                <TextBox x:Name="WidthTextBox" Grid.Column="1" Padding="6,4" />
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="输出高度" />
                <TextBox x:Name="HeightTextBox" Grid.Column="1" Padding="6,4" />
            </Grid>

            <TextBlock
                x:Name="ErrorTextBlock"
                Grid.Row="4"
                Foreground="#FFB3261E"
                TextWrapping="Wrap" />

            <StackPanel
                Grid.Row="5"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="80"
                    Margin="0,10,8,0"
                    Click="CancelButton_Click"
                    Content="取消" />
                <Button
                    Width="80"
                    Margin="0,10,0,0"
                    Click="ExportButton_Click"
                    Content="导出" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
