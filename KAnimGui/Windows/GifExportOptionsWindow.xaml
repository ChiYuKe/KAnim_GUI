<Window
    x:Class="KAnimGui.Windows.GifExportOptionsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="GIF 导出设置"
    Width="380"
    Height="530"
    Background="{DynamicResource WorkspaceBackgroundBrush}"
    FontFamily="{DynamicResource AppFontFamily}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    ShowActivated="True"
    TextElement.Foreground="{DynamicResource PanelTitleBrush}"
    WindowStartupLocation="CenterOwner">
    <Border Padding="20" Background="{DynamicResource PanelBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,16"
                FontSize="18"
                FontWeight="SemiBold"
                Text="GIF 导出设置" />

            <TextBlock
                Grid.Row="1"
                Margin="0,0,0,10"
                Foreground="{DynamicResource MutedTextBrush}"
                Text="播放速度以动画原始速度为基准：1.0 倍为原速。"
                TextWrapping="Wrap" />

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="播放速度 (倍速)" />
                <TextBox x:Name="PlaybackSpeedTextBox" Grid.Column="1" Padding="6,4" />
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="输出宽度" />
                <TextBox x:Name="WidthTextBox" Grid.Column="1" Padding="6,4" />
            </Grid>

            <Grid Grid.Row="4" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="输出高度" />
                <TextBox x:Name="HeightTextBox" Grid.Column="1" Padding="6,4" />
            </Grid>

            <Grid Grid.Row="5" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="缩放算法 (抗锯齿)" />
                <ComboBox x:Name="ScalingModeComboBox" Grid.Column="1" Padding="6,4">
                    <ComboBoxItem Content="Lanczos（推荐，平滑）" />
                    <ComboBoxItem Content="Bicubic（柔和）" />
                    <ComboBoxItem Content="Spline（细腻）" />
                    <ComboBoxItem Content="Nearest（像素风格）" />
                </ComboBox>
            </Grid>

            <Grid Grid.Row="6" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="输出目录" />
                <TextBox
                    x:Name="OutputDirectoryTextBox"
                    Grid.Column="1"
                    Padding="6,4"
                    ToolTip="单个导出使用此目录；批量导出会在此目录下按 KAnim 名称建立子目录" />
                <Button
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    Click="BrowseOutputDirectoryButton_Click"
                    Content="浏览"
                    Style="{StaticResource DialogActionButton}" />
            </Grid>

            <CheckBox
                x:Name="ShowCompletionNotificationCheckBox"
                Grid.Row="7"
                Margin="0,0,0,10"
                Content="导出完成后显示通知" />

            <TextBlock
                x:Name="ErrorTextBlock"
                Grid.Row="8"
                Foreground="{DynamicResource ErrorBrush}"
                TextWrapping="Wrap" />

            <StackPanel
                Grid.Row="9"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="80"
                    Margin="0,10,8,0"
                    Click="CancelButton_Click"
                    Content="取消"
                    Style="{StaticResource DialogActionButton}" />
                <Button
                    Width="80"
                    Margin="0,10,0,0"
                    Click="ExportButton_Click"
                    Content="导出"
                    Style="{StaticResource DialogPrimaryButton}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
