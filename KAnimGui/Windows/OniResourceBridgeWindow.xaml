<Window
    x:Class="KAnimGui.Windows.OniResourceBridgeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="ONI 资源桥"
    Width="1120"
    Height="720"
    MinWidth="980"
    MinHeight="620"
    FontFamily="Microsoft YaHei UI"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBarBrush" Color="#FF94435D" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#FFE7CED8" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FF6B2742" />

        <Style x:Key="PrimaryActionButton" BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#FF6750A4" />
            <Setter Property="BorderBrush" Value="#FF4B2394" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SecondaryActionButton" BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#FFFFF7FA" />
            <Setter Property="BorderBrush" Value="#FFFFF7FA" />
            <Setter Property="Foreground" Value="#FF6B2742" />
        </Style>

        <Style x:Key="IconActionButton" BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFFF7FA" />
            <Setter Property="BorderBrush" Value="#FFFFF7FA" />
            <Setter Property="Foreground" Value="#FF6B2742" />
        </Style>

        <Style x:Key="DetailPillText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF8A3D5A" />
        </Style>

        <Style TargetType="ListViewItem">
            <Style.Triggers>
                <DataTrigger Binding="{Binding CanImport}" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource AppBarBrush}">
            <DockPanel Margin="14,0">
                <Button
                    DockPanel.Dock="Right"
                    Width="40"
                    Height="40"
                    Click="SettingsButton_Click"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="设置"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        Kind="Cog" />
                </Button>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="17"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="ONI 资源桥" />
                <TextBlock
                    x:Name="ConnectionText"
                    Margin="20,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="#FFFFEAF1"
                    Text="未连接" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16,14,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="FilterTextBox"
                Grid.Column="0"
                Height="36"
                Width="300"
                HorizontalAlignment="Left"
                materialDesign:HintAssist.Hint="搜索 KAnim"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                TextChanged="FilterTextBox_TextChanged" />

            <ComboBox
                x:Name="ResourceTypeComboBox"
                Grid.Column="1"
                Width="104"
                MinHeight="36"
                Margin="16,0,0,0"
                Padding="10,0"
                SelectionChanged="ResourceTypeComboBox_SelectionChanged"
                SelectedIndex="0"
                VerticalContentAlignment="Center"
                Style="{StaticResource MaterialDesignOutlinedComboBox}">
                <ComboBoxItem Content="KAnim" />
                <ComboBoxItem Content="Sprite" />
            </ComboBox>

            <Button
                x:Name="RefreshButton"
                Grid.Column="2"
                Margin="16,0,0,0"
                Click="RefreshButton_Click"
                Content="{materialDesign:PackIcon Kind=Refresh}"
                Style="{StaticResource IconActionButton}"
                ToolTip="刷新" />

            <Button
                x:Name="ImportButton"
                Grid.Column="3"
                Margin="12,0,0,0"
                Click="ImportButton_Click"
                Content="导入选中"
                IsEnabled="False"
                Style="{StaticResource PrimaryActionButton}" />

            <Menu
                Grid.Column="5"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Background="Transparent">
                <MenuItem Header="更多" MinWidth="58">
                    <MenuItem Header="打开导出目录" Width="180" Click="OpenExportFolderButton_Click" />
                </MenuItem>
            </Menu>

            <Button
                x:Name="ExportFilteredButton"
                Grid.Column="4"
                Margin="12,0,0,0"
                Click="ExportFilteredButton_Click"
                Content="批量导出"
                Style="{StaticResource SecondaryActionButton}" />

            <Button
                x:Name="CancelBatchButton"
                Grid.Column="6"
                Margin="12,0,0,0"
                Click="CancelBatchButton_Click"
                Content="取消"
                Style="{StaticResource SecondaryActionButton}"
                Visibility="Collapsed" />
        </Grid>

        <Border
            Grid.Row="2"
            Margin="16,0,16,8"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <ListView
                    x:Name="AnimListView"
                    Grid.Column="0"
                    BorderThickness="0"
                    SelectionMode="Extended"
                    ScrollViewer.CanContentScroll="True"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    SelectionChanged="AnimListView_SelectionChanged">
                    <ListView.View>
                        <GridView x:Name="AnimGridView">
                            <GridViewColumn Width="520">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Height="58">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Grid.Column="0"
                                                Width="44"
                                                Height="44"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="#FFF4EEF1"
                                                BorderBrush="#FFE7CED8"
                                                BorderThickness="1">
                                                <Grid>
                                                    <Image
                                                        Width="42"
                                                        Height="42"
                                                        Source="{Binding Thumbnail}"
                                                        Stretch="Uniform" />
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="10"
                                                        Foreground="#FF9E7A86"
                                                        Text="无图">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasThumbnail}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border
                                                        Margin="0,0,8,0"
                                                        Padding="6,1"
                                                        Background="#FFF5E6EC"
                                                        BorderBrush="#FFD9A9BA"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                        <TextBlock
                                                            FontSize="10"
                                                            Foreground="#FF8A3D5A"
                                                            Text="{Binding SourceLabel}" />
                                                    </Border>
                                                <TextBlock
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="#FFD18B00"
                                                    Text="{Binding FavoriteGlyph}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Name}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="#FF9E6B7C"
                                                    Text="{Binding ImportStatus}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanImport}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    FontSize="10"
                                                    Foreground="#FFB06A80"
                                                    Text="{Binding TagText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasTags}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="160">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="#FF6B2742"
                                            Text="{Binding SummaryText}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Border
                    x:Name="DetailPanelBorder"
                    Grid.Column="1"
                    Padding="18"
                    Background="#FFFFFBFD"
                    BorderBrush="#FFE7CED8"
                    BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="#FF4A1F30"
                                Text="资源详情" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border
                                    Padding="8,2"
                                    Background="#FFF5E6EC"
                                    BorderBrush="#FFD9A9BA"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <TextBlock
                                        x:Name="DetailTypeTextBlock"
                                        Style="{StaticResource DetailPillText}"
                                        Text="-" />
                                </Border>
                                <Border
                                    Margin="6,0,0,0"
                                    Padding="8,2"
                                    Background="#FFFFF4F8"
                                    BorderBrush="#FFD9A9BA"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <TextBlock
                                        x:Name="DetailSourceTextBlock"
                                        Style="{StaticResource DetailPillText}"
                                        Text="-" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border
                            Grid.Row="1"
                            Margin="0,16,0,0"
                            Height="190"
                            Background="#FFF8F0F4"
                            BorderBrush="#FFE7CED8"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid>
                                <Image
                                    x:Name="DetailPreviewImage"
                                    Margin="10"
                                    Stretch="Uniform" />
                                <StackPanel
                                    x:Name="DetailPreviewEmptyText"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <materialDesign:PackIcon
                                        Width="28"
                                        Height="28"
                                        HorizontalAlignment="Center"
                                        Foreground="#FFB88999"
                                        Kind="ImageOffOutline" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        Foreground="#FF9E7A86"
                                        Text="无预览" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="2" Margin="0,14,0,0">
                            <TextBlock
                                x:Name="DetailNameTextBlock"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#FF231018"
                                Text="-"
                                TextWrapping="Wrap" />
                            <TextBlock
                                x:Name="DetailSummaryTextBlock"
                                Margin="0,8,0,0"
                                Foreground="#FF6B2742"
                                Text="-"
                                TextWrapping="Wrap" />
                            <TextBlock
                                x:Name="DetailStatusTextBlock"
                                Margin="0,6,0,0"
                                FontSize="12"
                                Foreground="#FF9E6B7C"
                                Text="-"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel
                            Grid.Row="4"
                            Margin="0,12,0,0">
                            <WrapPanel>
                                <Button
                                    x:Name="DetailExportButton"
                                    Margin="0,0,8,8"
                                    Click="DetailExportButton_Click"
                                    Content="仅导出当前"
                                    Style="{StaticResource PrimaryActionButton}" />
                                <Button
                                    x:Name="DetailOpenFolderButton"
                                    Margin="0,0,8,8"
                                    Click="DetailOpenFolderButton_Click"
                                    Content="打开导出目录"
                                    Style="{StaticResource SecondaryActionButton}" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="16,0,16,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="StatusTextBlock"
                Grid.Column="0"
                VerticalAlignment="Center"
                Foreground="{StaticResource MutedTextBrush}"
                Text="等待连接" />
            <ProgressBar
                x:Name="BusyProgressBar"
                Grid.Column="1"
                Width="120"
                Height="4"
                IsIndeterminate="True"
                Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
