<UserControl
    x:Class="KAnimGui.Windows.KAnimRenderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:preview="clr-namespace:KAnimGui.Presentation.Preview"
    AllowDrop="True"
    Focusable="True"
    FontFamily="{DynamicResource AppFontFamily}"
    SnapsToDevicePixels="True"
    TextElement.Foreground="{DynamicResource PanelTitleBrush}"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True">
    <!--  MouseDown 拖动事件  -->

    <UserControl.Resources>
        <!--  复制 MainWindow 的资源  -->
        <SolidColorBrush x:Key="PrimaryColor" Color="{DynamicResource ThemePrimaryColor}" />
        <SolidColorBrush x:Key="SecondaryColor" Color="{DynamicResource ThemeSecondaryColor}" />
        <SolidColorBrush x:Key="AccentColor" Color="{DynamicResource ThemeAccentColor}" />
        <SolidColorBrush x:Key="AppBarBrush" Color="{DynamicResource ThemeAppBarColor}" />
        <SolidColorBrush x:Key="WorkspaceBackgroundBrush" Color="{DynamicResource ThemeWorkspaceColor}" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{DynamicResource ThemePanelColor}" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="{DynamicResource ThemePanelBorderColor}" />
        <SolidColorBrush x:Key="PreviewBackgroundBrush" Color="{DynamicResource ThemePreviewColor}" />
        <SolidColorBrush x:Key="PreviewBorderBrush" Color="{DynamicResource ThemePreviewBorderColor}" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="{DynamicResource ThemeMutedColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource ThemePrimaryColor}" />
        <SolidColorBrush x:Key="SoftAccentBrush" Color="{DynamicResource ThemeSoftAccentColor}" />
        <SolidColorBrush x:Key="GridLineBrush" Color="{DynamicResource ThemeGridLineColor}" />
        <SolidColorBrush x:Key="PanelTitleBrush" Color="{DynamicResource ThemePanelTitleColor}" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="{DynamicResource ThemeSubtleColor}" />
        <Style BasedOn="{StaticResource WorkspaceTabItemStyle}" TargetType="TabItem" />

        <Style x:Key="PreviewIconButton" TargetType="Button" BasedOn="{StaticResource AppButtonBase}">
            <Setter Property="Width" Value="38" />
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource PrimaryActionBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryActionHoverBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryActionPressedBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewPrimaryIconButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
            <Setter Property="Width" Value="40" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="PreviewSectionTitleText" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
            <Setter Property="FontSize" Value="16" />
        </Style>

        <Style
            x:Key="PreviewTopMenuItemStyle"
            TargetType="MenuItem"
            BasedOn="{StaticResource {x:Type MenuItem}}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource AppBarForegroundBrush}" />
            <Setter
                Property="materialDesign:MenuItemAssist.HighlightedBackground"
                Value="{DynamicResource SelectedBrush}" />
        </Style>

        <Style x:Key="PreviewPanelCardStyle" TargetType="materialDesign:Card">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Effect" Value="{StaticResource WorkspaceCardShadow}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UniformCornerRadius" Value="12" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0" />
        </Style>
    </UserControl.Resources>



    <DockPanel Background="{StaticResource WorkspaceBackgroundBrush}">
        <Border
            DockPanel.Dock="Top"
            Height="72"
            Background="{StaticResource AppBarBrush}">
            <Grid Margin="16,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Width="34"
                        Height="34"
                        Background="{DynamicResource SelectedBrush}"
                        CornerRadius="9">
                        <materialDesign:PackIcon
                            Width="19"
                            Height="19"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource AccentBrush}"
                            Kind="AnimationPlayOutline" />
                    </Border>
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AppBarForegroundBrush}"
                        Text="KAnim 预览器" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Width="1"
                    Height="24"
                    Margin="18,0,10,0"
                    VerticalAlignment="Center"
                    Background="{DynamicResource PanelBorderBrush}" />

                <Menu
                    Grid.Column="2"
                    Height="44"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="Transparent">
                    <Menu.Resources>
                        <Style BasedOn="{StaticResource {x:Type MenuItem}}" TargetType="{x:Type MenuItem}">
                            <Setter Property="Foreground" Value="{DynamicResource PanelTitleBrush}" />
                            <Setter Property="FontSize" Value="14" />
                        </Style>
                    </Menu.Resources>
                    <MenuItem Header="文件" Style="{StaticResource PreviewTopMenuItemStyle}">
                        <MenuItem Header="打开..." Name="MenuOpen" />
                        <MenuItem Header="导出 PNG" Name="MenuExportPng" />
                        <MenuItem Header="导出 GIF（设置）..." Name="MenuExportGif" />
                        <MenuItem Header="批量导出 GIF（设置）..." Name="MenuExportAllGif" />
                        <Separator />
                        <MenuItem Header="返回转换" Name="MenuExit" />
                    </MenuItem>
                    <MenuItem Header="视图" Style="{StaticResource PreviewTopMenuItemStyle}">
                        <MenuItem x:Name="MenuBackgroundBlack" Header="背景颜色：黑色" />
                        <MenuItem x:Name="MenuBackgroundWhite" Header="背景颜色：白色" />
                    </MenuItem>
                    <MenuItem Header="动画" Style="{StaticResource PreviewTopMenuItemStyle}">
                        <MenuItem x:Name="MenuPlayPause" Header="播放/暂停" />
                        <MenuItem x:Name="MenuPreviousFrame" Header="上一帧" />
                        <MenuItem x:Name="MenuNextFrame" Header="下一帧" />
                    </MenuItem>
                    <MenuItem Header="诊断" Style="{StaticResource PreviewTopMenuItemStyle}">
                        <MenuItem x:Name="MenuDiagnosePackage" Header="诊断当前包" />
                    </MenuItem>
                    <MenuItem
                        x:Name="MenuSettings"
                        Header="设置"
                        Style="{StaticResource PreviewTopMenuItemStyle}" />
                </Menu>
            </Grid>
        </Border>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" MinWidth="280" />
                <ColumnDefinition Width="*" MinWidth="480" />
                <ColumnDefinition Width="310" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card
                Grid.Column="0"
                Margin="0,0,10,0"
                Padding="12"
                Style="{StaticResource PreviewPanelCardStyle}">
                <DockPanel FocusVisualStyle="{x:Null}">
                    <Border
                        Margin="0,0,0,8"
                        DockPanel.Dock="Top"
                        Padding="0,0,0,6"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Border
                                Width="4"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="2" />
                            <TextBlock
                                FocusVisualStyle="{x:Null}"
                                Style="{StaticResource PreviewSectionTitleText}"
                                Text="资源索引" />
                        </DockPanel>
                    </Border>

                    <TextBox
                        x:Name="TreeSearchBox"
                        Margin="0,0,0,8"
                        DockPanel.Dock="Top"
                        materialDesign:HintAssist.Hint="搜索 symbol / animation"
                        />

                    <TreeView
                        x:Name="BuildTreeView"
                        Background="Transparent"
                        Foreground="{StaticResource PanelTitleBrush}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        Style="{StaticResource MaterialDesignTreeView}"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling">
                        <TreeView.Resources>
                            <ContextMenu
                                x:Key="TreeViewItemContextMenu"
                                Padding="0"
                                Background="{StaticResource PanelBackgroundBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1">
                                <MenuItem
                                    x:Name="ExportSelectedImageMenu"
                                    FontSize="14"
                                    Header="导出图片" />
                                <MenuItem
                                    x:Name="ReplaceSelectedImageMenu"
                                    FontSize="14"
                                    Header="替换图片" />
                            </ContextMenu>

                            <Style BasedOn="{StaticResource {x:Type TreeViewItem}}" TargetType="TreeViewItem">
                                <Setter Property="ContextMenu" Value="{StaticResource TreeViewItemContextMenu}" />
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MaxWidth" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type TreeView}}, Path=ActualWidth}" />
                                <Setter Property="Padding" Value="2,3" />
                            </Style>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>
            </materialDesign:Card>

            <Border
                x:Name="PreviewSurface"
                Grid.Column="1"
                Margin="0,0,10,0"
                AllowDrop="True"
                Background="{StaticResource PreviewBackgroundBrush}"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="12"
                Effect="{StaticResource WorkspaceCardShadow}"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <preview:AnimationViewport
                    x:Name="PreviewViewport"
                    FocusVisualStyle="{x:Null}" />
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <materialDesign:Card
                    x:Name="DropCard"
                    Grid.Row="0"
                    MinHeight="112"
                    Margin="0,0,0,10"
                    Padding="12"
                    AllowDrop="True"
                    Style="{StaticResource PreviewPanelCardStyle}">
                    <DockPanel>
                        <DockPanel
                            Margin="0,0,0,8"
                            DockPanel.Dock="Top">
                            <Border
                                Width="4"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="2" />
                            <TextBlock
                                Style="{StaticResource PreviewSectionTitleText}"
                                Text="文件" />
                        </DockPanel>
                        <StackPanel
                            x:Name="ContentPanel"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <materialDesign:PackIcon
                                x:Name="UploadIcon"
                                Width="28"
                                Height="28"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource AppBarBrush}"
                                Kind="FileUpload" />
                            <TextBlock
                                x:Name="HintText"
                                MaxWidth="230"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="{StaticResource MutedTextBrush}"
                                Text="拖放 .png、_anim、_build 文件到此处"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </DockPanel>
                </materialDesign:Card>

                <materialDesign:Card
                    Grid.Row="1"
                    Margin="0,0,0,10"
                    Padding="1"
                    Style="{StaticResource PreviewPanelCardStyle}">
                    <DockPanel>
                        <DockPanel
                            Margin="12,10,12,8"
                            DockPanel.Dock="Top"
                            LastChildFill="True">
                            <Border
                                Width="4"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="2" />
                            <TextBlock
                                Style="{StaticResource PreviewSectionTitleText}"
                                Text="属性" />
                        </DockPanel>
                        <TabControl Background="Transparent">
                            <TabItem Header="属性">
                                <DataGrid
                                    x:Name="ParameterDataGrid"
                                    AutoGenerateColumns="False"
                                    CanUserResizeColumns="False"
                                    CanUserResizeRows="False"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    GridLinesVisibility="Horizontal"
                                    HorizontalGridLinesBrush="{StaticResource GridLineBrush}"
                                    HeadersVisibility="Column"
                                    IsReadOnly="True"
                                    RowBackground="{StaticResource PanelBackgroundBrush}"
                                    AlternatingRowBackground="{StaticResource SoftAccentBrush}"
                                    Foreground="{StaticResource PanelTitleBrush}"
                                    SelectionMode="Single"
                                    SelectionUnit="Cell"
                                    VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Key}"
                                            Header="参数名" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Value}"
                                            Header="属性值" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="帧">
                                <ListBox
                                    x:Name="FrameListBox"
                                    BorderThickness="0"
                                    DisplayMemberPath="Title" />
                            </TabItem>
                            <TabItem Header="元素">
                                <ListBox
                                    x:Name="ElementListBox"
                                    BorderThickness="0"
                                    DisplayMemberPath="Title" />
                            </TabItem>
                        </TabControl>
                    </DockPanel>
                </materialDesign:Card>

                <materialDesign:Card
                    Grid.Row="2"
                    Padding="12"
                    Style="{StaticResource PreviewPanelCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel
                            Grid.Row="0"
                            Margin="0,0,0,8">
                            <Border
                                Width="4"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="2" />
                            <TextBlock
                                Style="{StaticResource PreviewSectionTitleText}"
                                Text="动画" />
                        </DockPanel>

                        <ComboBox
                            x:Name="AnimationComboBox"
                            Grid.Row="1"
                            Margin="0,0,0,8"
                            DisplayMemberPath="Name"
                            Style="{StaticResource AppCompactComboBoxStyle}"
                            materialDesign:HintAssist.Hint="动画"
                            ToolTip="鼠标悬停后滚动切换动画" />

                        <StackPanel
                            Grid.Row="2"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                x:Name="PreviousFrameButton"
                                Content="{materialDesign:PackIcon Kind=SkipPrevious}"
                                FocusVisualStyle="{x:Null}"
                                Style="{StaticResource PreviewIconButton}"
                                ToolTip="上一帧" />
                            <Button
                                x:Name="PlayPauseButton"
                                Content="{materialDesign:PackIcon Kind=Play}"
                                FocusVisualStyle="{x:Null}"
                                Style="{StaticResource PreviewPrimaryIconButton}"
                                ToolTip="播放/暂停" />
                            <Button
                                x:Name="NextFrameButton"
                                Content="{materialDesign:PackIcon Kind=SkipNext}"
                                FocusVisualStyle="{x:Null}"
                                Style="{StaticResource PreviewIconButton}"
                                ToolTip="下一帧" />
                        </StackPanel>

                        <TextBlock
                            x:Name="FrameStatusText"
                            Grid.Row="3"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="未加载动画" />

                        <Slider
                            x:Name="FrameSlider"
                            Grid.Row="4"
                            Margin="0,8,0,4"
                            IsSnapToTickEnabled="True"
                            Minimum="0"
                            TickFrequency="1"
                            />

                        <Grid
                            Grid.Row="5"
                            Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="PlaybackSpeedText"
                                Width="72"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource MutedTextBrush}"
                                Text="速度 1.00x" />
                            <Slider
                                x:Name="PlaybackSpeedSlider"
                                Grid.Column="1"
                                IsSnapToTickEnabled="False"
                                LargeChange="0.1"
                                Maximum="2"
                                Minimum="0.1"
                                SmallChange="0.05"
                                Value="1"
                                />
                        </Grid>

                        <WrapPanel
                            Grid.Row="6"
                            Margin="0,6,0,0">
                            <CheckBox
                                x:Name="ShowOriginCheckBox"
                                Margin="0,0,8,0"
                                Content="原点"
                                IsChecked="True"
                                />
                            <CheckBox
                                x:Name="ShowBoundsCheckBox"
                                Margin="0,0,8,0"
                                Content="盒"
                                />
                            <CheckBox
                                x:Name="HighlightElementCheckBox"
                                Content="高亮"
                                IsChecked="True"
                                />
                        </WrapPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </DockPanel>





</UserControl>
