<Window
    x:Class="KAnimGui.Windows.KAnimRenderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:preview="clr-namespace:KAnimGui.Presentation.Preview"
    Title="Anim Render Window"
    Width="1280"
    Height="800"
    FontFamily="Microsoft YaHei UI"
    SizeToContent="Manual"
    SnapsToDevicePixels="True"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterOwner">
    <!--  MouseDown 拖动事件  -->

    <Window.Resources>
        <!--  复制 MainWindow 的资源  -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#FF6750A4" />
        <SolidColorBrush x:Key="SecondaryColor" Color="#FFE8DEF8" />
        <SolidColorBrush x:Key="AccentColor" Color="#FF7E5260" />
        <SolidColorBrush x:Key="AppBarBrush" Color="#FF94435D" />
        <SolidColorBrush x:Key="WorkspaceBackgroundBrush" Color="#FF90455D" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#FFE7CED8" />
        <SolidColorBrush x:Key="PreviewBackgroundBrush" Color="#FF969696" />
        <SolidColorBrush x:Key="PreviewBorderBrush" Color="#FFF2DDE6" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FF6B2742" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF6750A4" />
        <SolidColorBrush x:Key="SoftAccentBrush" Color="#FFFFF7FA" />
        <SolidColorBrush x:Key="GridLineBrush" Color="#FFE8DCE2" />
        <SolidColorBrush x:Key="PanelTitleBrush" Color="#FF4F2033" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#FF8A5B6C" />
        <DrawingBrush
            x:Key="PreviewGridBrush"
            TileMode="Tile"
            Viewport="0,0,96,96"
            ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{StaticResource PreviewBackgroundBrush}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,96,96" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#55FFFFFF" Thickness="1" />
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="48,0" EndPoint="48,96" />
                                <LineGeometry StartPoint="0,48" EndPoint="96,48" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#A5FFFFFF" Thickness="1.4" />
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="96,0" />
                                <LineGeometry StartPoint="0,0" EndPoint="0,96" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style BasedOn="{StaticResource MaterialDesignNavigationRailTabItem}" TargetType="TabItem">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueLightBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid>
                            <Border
                                Name="Border"
                                Margin="{TemplateBinding Margin}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2"
                                CornerRadius="4 4 0 0">
                                <ContentPresenter
                                    x:Name="ContentSite"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    ContentSource="Header" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}" />
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryHueLightBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueDarkBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryHueLightBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueDarkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Width" Value="100" />
        </Style>

        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PanelTitleBrush}" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="materialDesign:Card">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UniformCornerRadius" Value="6" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0" />
        </Style>
    </Window.Resources>



    <DockPanel Background="{StaticResource WorkspaceBackgroundBrush}">
        <Border
            DockPanel.Dock="Top"
            Height="48"
            Background="{StaticResource AppBarBrush}">
            <DockPanel>
                <TextBlock
                    Margin="15,0"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="KAnim 预览器" />
                <Menu
                    DockPanel.Dock="Left"
                    Padding="6,4"
                    Background="Transparent">
                    <Menu.Resources>
                        <Style BasedOn="{StaticResource {x:Type MenuItem}}" TargetType="{x:Type MenuItem}">
                            <Setter Property="Foreground" Value="#FF222222" />
                            <Setter Property="FontSize" Value="14" />
                        </Style>
                    </Menu.Resources>
                    <MenuItem Header="文件" Foreground="White">
                        <MenuItem Header="打开..." Name="MenuOpen" />
                        <MenuItem Header="导出 PNG" Name="MenuExportPng" />
                        <Separator />
                        <MenuItem Header="退出" Name="MenuExit" />
                    </MenuItem>
                    <MenuItem Header="视图" Foreground="White">
                        <MenuItem x:Name="MenuBackgroundBlack" Header="背景颜色：黑色" />
                        <MenuItem x:Name="MenuBackgroundWhite" Header="背景颜色：白色" />
                    </MenuItem>
                    <MenuItem Header="动画" Foreground="White">
                        <MenuItem x:Name="MenuPlayPause" Header="播放/暂停" />
                        <MenuItem x:Name="MenuPreviousFrame" Header="上一帧" />
                        <MenuItem x:Name="MenuNextFrame" Header="下一帧" />
                    </MenuItem>
                    <MenuItem Header="诊断" Foreground="White">
                        <MenuItem x:Name="MenuDiagnosePackage" Header="诊断当前包" />
                    </MenuItem>
                </Menu>
            </DockPanel>
        </Border>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" MinWidth="280" />
                <ColumnDefinition Width="*" MinWidth="480" />
                <ColumnDefinition Width="310" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card
                Grid.Column="0"
                Margin="0,0,10,0"
                Padding="12"
                Style="{StaticResource PanelCardStyle}">
                <DockPanel FocusVisualStyle="{x:Null}">
                    <Border
                        Margin="0,0,0,8"
                        DockPanel.Dock="Top"
                        Padding="0,0,0,6"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Border
                                Width="4"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="{StaticResource AppBarBrush}"
                                CornerRadius="2" />
                            <TextBlock
                                FocusVisualStyle="{x:Null}"
                                Style="{StaticResource SectionTitleText}"
                                Text="资源索引" />
                        </DockPanel>
                    </Border>

                    <TextBox
                        x:Name="TreeSearchBox"
                        Margin="0,0,0,8"
                        DockPanel.Dock="Top"
                        materialDesign:HintAssist.Hint="搜索 symbol / animation"
                        />

                    <TreeView
                        x:Name="BuildTreeView"
                        Background="Transparent"
                        Foreground="{StaticResource PanelTitleBrush}"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        Style="{StaticResource MaterialDesignTreeView}"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling">
                        <TreeView.Resources>
                            <ContextMenu
                                x:Key="TreeViewItemContextMenu"
                                Padding="0"
                                Background="{StaticResource PanelBackgroundBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1">
                                <MenuItem
                                    x:Name="ExportSelectedImageMenu"
                                    FontSize="14"
                                    Header="导出图片" />
                                <MenuItem
                                    x:Name="ReplaceSelectedImageMenu"
                                    FontSize="14"
                                    Header="替换图片" />
                            </ContextMenu>

                            <Style BasedOn="{StaticResource {x:Type TreeViewItem}}" TargetType="TreeViewItem">
                                <Setter Property="ContextMenu" Value="{StaticResource TreeViewItemContextMenu}" />
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="Padding" Value="2,3" />
                            </Style>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>
            </materialDesign:Card>

            <Border
                x:Name="PreviewSurface"
                Grid.Column="1"
                Margin="0,0,10,0"
                AllowDrop="True"
                Background="{StaticResource PreviewGridBrush}"
                BorderBrush="{StaticResource PreviewBorderBrush}"
                BorderThickness="3"
                CornerRadius="8"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <preview:AnimationViewport x:Name="PreviewViewport" />
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <materialDesign:Card
                    x:Name="DropCard"
                    Grid.Row="0"
                    MinHeight="112"
                    Margin="0,0,0,10"
                    Padding="12"
                    AllowDrop="True"
                    Style="{StaticResource PanelCardStyle}">
                    <DockPanel>
                        <DockPanel
                            Margin="0,0,0,8"
                            DockPanel.Dock="Top">
                            <Border
                                Width="4"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="{StaticResource AppBarBrush}"
                                CornerRadius="2" />
                            <TextBlock
                                Style="{StaticResource SectionTitleText}"
                                Text="文件" />
                        </DockPanel>
                        <StackPanel
                            x:Name="ContentPanel"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <materialDesign:PackIcon
                                x:Name="UploadIcon"
                                Width="28"
                                Height="28"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource AppBarBrush}"
                                Kind="FileUpload" />
                            <TextBlock
                                x:Name="HintText"
                                MaxWidth="230"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="{StaticResource MutedTextBrush}"
                                Text="拖放 .png、_anim、_build 文件到此处"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </DockPanel>
                </materialDesign:Card>

                <materialDesign:Card
                    Grid.Row="1"
                    Margin="0,0,0,10"
                    Padding="1"
                    Style="{StaticResource PanelCardStyle}">
                    <DockPanel>
                        <DockPanel
                            Margin="12,10,12,8"
                            DockPanel.Dock="Top"
                            LastChildFill="True">
                            <Border
                                Width="4"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="{StaticResource AppBarBrush}"
                                CornerRadius="2" />
                            <TextBlock
                                Style="{StaticResource SectionTitleText}"
                                Text="属性" />
                        </DockPanel>
                        <TabControl Background="Transparent">
                            <TabItem Header="属性">
                                <DataGrid
                                    x:Name="ParameterDataGrid"
                                    AutoGenerateColumns="False"
                                    CanUserResizeColumns="False"
                                    CanUserResizeRows="False"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    GridLinesVisibility="Horizontal"
                                    HorizontalGridLinesBrush="{StaticResource GridLineBrush}"
                                    HeadersVisibility="Column"
                                    IsReadOnly="True"
                                    RowBackground="{StaticResource PanelBackgroundBrush}"
                                    AlternatingRowBackground="{StaticResource SoftAccentBrush}"
                                    Foreground="{StaticResource PanelTitleBrush}"
                                    SelectionMode="Single"
                                    SelectionUnit="Cell"
                                    VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Key}"
                                            Header="参数名" />
                                        <DataGridTextColumn
                                            Width="*"
                                            Binding="{Binding Value}"
                                            Header="属性值" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="帧">
                                <ListBox
                                    x:Name="FrameListBox"
                                    BorderThickness="0"
                                    DisplayMemberPath="Title" />
                            </TabItem>
                            <TabItem Header="元素">
                                <ListBox
                                    x:Name="ElementListBox"
                                    BorderThickness="0"
                                    DisplayMemberPath="Title" />
                            </TabItem>
                        </TabControl>
                    </DockPanel>
                </materialDesign:Card>

                <materialDesign:Card
                    Grid.Row="2"
                    Padding="12"
                    Style="{StaticResource PanelCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel
                            Grid.Row="0"
                            Margin="0,0,0,8">
                            <Border
                                Width="4"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="{StaticResource AppBarBrush}"
                                CornerRadius="2" />
                            <TextBlock
                                Style="{StaticResource SectionTitleText}"
                                Text="动画" />
                        </DockPanel>

                        <ComboBox
                            x:Name="AnimationComboBox"
                            Grid.Row="1"
                            Margin="0,0,0,8"
                            DisplayMemberPath="Name"
                            Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                            materialDesign:HintAssist.Hint="动画" />

                        <StackPanel
                            Grid.Row="2"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                x:Name="PreviousFrameButton"
                                Content="{materialDesign:PackIcon Kind=SkipPrevious}"
                                FocusVisualStyle="{x:Null}"
                                Foreground="{StaticResource PrimaryColor}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="上一帧" />
                            <Button
                                x:Name="PlayPauseButton"
                                Content="{materialDesign:PackIcon Kind=Play}"
                                FocusVisualStyle="{x:Null}"
                                Foreground="{StaticResource PrimaryColor}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="播放/暂停" />
                            <Button
                                x:Name="NextFrameButton"
                                Content="{materialDesign:PackIcon Kind=SkipNext}"
                                FocusVisualStyle="{x:Null}"
                                Foreground="{StaticResource PrimaryColor}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="下一帧" />
                        </StackPanel>

                        <TextBlock
                            x:Name="FrameStatusText"
                            Grid.Row="3"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0"
                            Foreground="{StaticResource MutedTextBrush}"
                            Text="未加载动画" />

                        <Slider
                            x:Name="FrameSlider"
                            Grid.Row="4"
                            Margin="0,8,0,4"
                            IsSnapToTickEnabled="True"
                            Minimum="0"
                            TickFrequency="1"
                            />

                        <Grid
                            Grid.Row="5"
                            Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="PlaybackSpeedText"
                                Width="72"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource MutedTextBrush}"
                                Text="速度 1.00x" />
                            <Slider
                                x:Name="PlaybackSpeedSlider"
                                Grid.Column="1"
                                IsSnapToTickEnabled="False"
                                LargeChange="0.1"
                                Maximum="2"
                                Minimum="0.1"
                                SmallChange="0.05"
                                Value="1"
                                />
                        </Grid>

                        <WrapPanel
                            Grid.Row="6"
                            Margin="0,6,0,0">
                            <CheckBox
                                x:Name="ShowOriginCheckBox"
                                Margin="0,0,8,0"
                                Content="原点"
                                IsChecked="True"
                                />
                            <CheckBox
                                x:Name="ShowBoundsCheckBox"
                                Margin="0,0,8,0"
                                Content="盒"
                                />
                            <CheckBox
                                x:Name="HighlightElementCheckBox"
                                Content="高亮"
                                IsChecked="True"
                                />
                        </WrapPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </DockPanel>





</Window>
